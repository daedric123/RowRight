# Copy this file to .env.local and fill in your values.
# Never commit .env.local — it is gitignored.

# ── Frontend (Vite) ──────────────────────────────────────────
# Found in: Supabase dashboard → Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Display only — shown in the UI next to seat pricing
VITE_STRIPE_SEAT_PRICE_USD=5.00

# ── Netlify Functions ────────────────────────────────────────
# Found in: Supabase dashboard → Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key   # Keep this secret — bypasses all RLS

# Found in: Stripe dashboard → Developers → API keys
STRIPE_SECRET_KEY=sk_test_...

# Found in: Stripe dashboard → Products → your per-seat price → Price ID
STRIPE_PRICE_ID=price_...

# Found in: Stripe dashboard → Developers → Webhooks → your endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_...

# Your deployed site's root URL — used to build Stripe redirect URLs.
# Netlify auto-provides this as URL in deployed environments.
# Set it explicitly here for local dev with `netlify dev`.
SITE_URL=https://your-site.netlify.app
